APP_NAME=Micro Niche Finder
APP_ENV=local
APP_DEBUG=true
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/micro_niche_finder
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_CANDIDATE_MODEL=gpt-5.4-mini
OPENAI_FINAL_MODEL=gpt-5.4
OPENAI_REASONING_EFFORT=medium
OPENAI_TEXT_VERBOSITY=medium
BRAVE_SEARCH_API_KEY=
BRAVE_SEARCH_BASE_URL=https://api.search.brave.com/res/v1/web/search
BRAVE_SEARCH_DAILY_LIMIT=100
KOSIS_API_KEY=
KOSIS_BASE_URL=https://kosis.kr/openapi/Param/statisticsParameterData.do
KOSIS_ORG_ID=101
KOSIS_TBL_ID=DT_1K52D01
KOSIS_EMPLOYEE_ITM_ID=
KOSIS_PRD_SE=Y
KOSIS_INDUSTRY_DIMENSION_KEY=objL1
KOSIS_REFERENCE_YEAR_OFFSET=1
KOSIS_EMPLOYEE_DAILY_LIMIT=100
KOSIS_EMPLOYEE_CADENCE_MINUTES=1440
KOSIS_STATIC_PARAMS_JSON=
KOSIS_INDUSTRY_OPTIONS_JSON={"classification":"KSIC10","level":"중분류","mapping":{"스마트스토어":"G47912","온라인교육":"P85659","헬스케어":"Q86","1인가구식품":"C107","물류자동화":"H52"}}
KOSIS_PROFILE_OPTIONS_JSON=[{"name":"business-structure","label":"Business structure","kind":"structure","tbl_id":"DT_1F2A01","metrics":{"business_count":"T1","employee_count":"T2"},"static_params":{"PRD_SE":"A"},"industry_dimension_key":"objL1","time_range":[2019,2023]},{"name":"service-economics","label":"Service economics","kind":"economics","tbl_id":"DT_1SB1501","metrics":{"business_count":"T1","employee_count":"T2","revenue":"T3","value_added":"T4"},"static_params":{"PRD_SE":"A"},"industry_dimension_key":"objL1","time_range":[2019,2023],"exclude_prefixes":["C"]},{"name":"manufacturing-economics","label":"Manufacturing economics","kind":"economics","tbl_id":"DT_1MC1503","metrics":{"employee_count":"T2","revenue":"T3"},"static_params":{"PRD_SE":"A"},"industry_dimension_key":"objL1","time_range":[2019,2023],"applies_to_prefixes":["C"]}]
NAVER_DATALAB_CLIENT_ID=
NAVER_DATALAB_CLIENT_SECRET=
NAVER_DATALAB_BASE_URL=https://openapi.naver.com/v1/datalab/search
NAVER_DATALAB_DAILY_LIMIT=1000
NAVER_SEARCH_CLIENT_ID=
NAVER_SEARCH_CLIENT_SECRET=
NAVER_SEARCH_BASE_URL=https://openapi.naver.com/v1/search/webkr.json
NAVER_SEARCH_DISPLAY=5
NAVER_SEARCH_DAILY_LIMIT=300
NAVER_SHOPPING_INSIGHT_BASE_URL=https://openapi.naver.com/v1/datalab/shopping/categories
NAVER_SHOPPING_INSIGHT_DAILY_LIMIT=300
NAVER_SHOPPING_INSIGHT_CADENCE_MINUTES=720
NAVER_SHOPPING_CATEGORY_OPTIONS_JSON=[{"code":"50000000","label":"패션의류","description":"의류 쇼핑몰, 의류 셀러, 시즌상품 운영"},{"code":"50000001","label":"패션잡화","description":"가방, 신발, 액세서리 판매 운영"},{"code":"50000002","label":"화장품/미용","description":"뷰티, 화장품, 미용 소모품 판매"},{"code":"50000003","label":"디지털/가전","description":"전자기기, 소형가전, 주변기기 판매"},{"code":"50000006","label":"식품","description":"식품, 건강식, 신선식품, 간편식 판매"},{"code":"50000008","label":"생활/건강","description":"생활용품, 건강용품, 반려/위생/소모품 판매"}]
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_BASE_URL=https://api.telegram.org
GMAIL_SMTP_HOST=smtp.gmail.com
GMAIL_SMTP_PORT=465
GMAIL_USERNAME=
GMAIL_APP_PASSWORD=
GMAIL_FROM_EMAIL=
GMAIL_TO_EMAILS=
DAILY_REPORT_TIMEZONE=Asia/Seoul
DAILY_REPORT_HOUR=9
DAILY_REPORT_MINUTE=0
DAILY_REPORT_SEED_LIMIT=5
DAILY_REPORT_CANDIDATE_COUNT=5
DAILY_REPORT_TOP_K_PER_SEED=1
COLLECTOR_INTERVAL_MINUTES=15
COLLECTOR_SCHEDULE_CADENCE_MINUTES=180
COLLECTOR_DEFAULT_PRIORITY=100
TOP_CANDIDATE_ANALYSIS_COUNT=10

# KOSIS integration — set to false to disable without removing API key
KOSIS_ENABLED=true

# Scoring dimension weights (must sum to ~1.0)
# Tune without code changes to adjust candidate ranking priorities
SCORE_WEIGHT_REPEATED_PAIN=0.17
SCORE_WEIGHT_PROBLEM_INTENSITY=0.14
SCORE_WEIGHT_PAYMENT_LIKELIHOOD=0.12
SCORE_WEIGHT_ONLINE_DEMAND=0.15
SCORE_WEIGHT_MARKET_SIZE_SUFFICIENCY=0.10
SCORE_WEIGHT_ONLINE_GTM_EFFICIENCY=0.12
SCORE_WEIGHT_MARKET_SIZE_CEILING=0.10
SCORE_WEIGHT_COMPETITIVE_WHITESPACE=0.06
SCORE_WEIGHT_KEYWORD_DIFFICULTY=0.08
SCORE_WEIGHT_IMPLEMENTATION_FEASIBILITY=0.04
