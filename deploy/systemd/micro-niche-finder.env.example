NAVER_SHOPPING_CATEGORY_OPTIONS_JSON=[{"code":"50000000","label":"패션의류","description":"의류 쇼핑몰, 의류 셀러, 시즌상품 운영"},{"code":"50000001","label":"패션잡화","description":"가방, 신발, 액세서리 판매 운영"},{"code":"50000002","label":"화장품/미용","description":"뷰티, 화장품, 미용 소모품 판매"},{"code":"50000003","label":"디지털/가전","description":"전자기기, 소형가전, 주변기기 판매"},{"code":"50000006","label":"식품","description":"식품, 건강식, 신선식품, 간편식 판매"},{"code":"50000008","label":"생활/건강","description":"생활용품, 건강용품, 반려/위생/소모품 판매"}]
